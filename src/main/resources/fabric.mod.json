{
  "schemaVersion": 1,
  "id": "gooberlib",
  "version": "${version}",
  "name": "GooberLib",
  "description": "GooberLib config library",
  "authors": [
    "NG5M",
    "Tektonikal",
    "kr1v"
  ],
  "contact": {},
  "license": "LGPL-3.0",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.goobercorp.gooberlib.GooberLibEntrypoint"
    ],
    "modmenu": [
      "com.goobercorp.gooberlib.compat.ModMenuIntegration"
    ]
  },
  "mixins": [
    "gooberlib.mixins.json"
  ],
  "accessWidener": "gooberlib.classtweaker",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  },
  "custom": {
    "modmenu": {
      "badges": [
        "library"
      ]
    }
  }
}
